# ClaudeCode Hub · docker compose environment
#
# ---------------------------------------------------------------------------
# 部署模式：决定哪些服务由 docker compose 启动
#   embedded  (默认) docker 自己拉 MySQL / Redis / RabbitMQ 容器，什么都不用装
#   external         只启动 backend + web（nginx），把下方的 CH_DB_* / CH_REDIS_*
#                    指到真实线上地址
# 多个 profile 用逗号分隔，如 `embedded,rabbitmq-ui`。
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=embedded

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
# embedded 模式：CH_DB_HOST 必须是 `mysql`（compose 服务名）
# external 模式：CH_DB_HOST 改成你的真实地址，并确保库已手动 import 过
#               db/schema-mysql.sql + db/seed-mysql.sql
CH_DB_HOST=mysql
CH_DB_PORT=3306
CH_DB_NAME=chhub
CH_DB_USER=chhub
CH_DB_PASSWORD=chhub_pwd
CH_DB_ROOT_PASSWORD=root_pwd_change_me

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
CH_REDIS_HOST=redis
CH_REDIS_PORT=6379
CH_REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# 安全
# ---------------------------------------------------------------------------
# 请在生产部署前改成 >=32 字符的随机串
CH_JWT_SECRET=please-change-me-this-is-compose-default-very-long-secret-xyz

# ---------------------------------------------------------------------------
# 前端 Nginx 暴露端口
# ---------------------------------------------------------------------------
CH_WEB_PORT=80

# ---------------------------------------------------------------------------
# RabbitMQ 管理面板端口（仅 embedded 模式）
# ---------------------------------------------------------------------------
CH_RABBITMQ_MGMT_PORT=15672
