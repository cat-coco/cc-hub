# Default values for `docker compose up` — works out-of-the-box with embedded
# MySQL / Redis containers. Copy .env.example to learn how to switch to an
# external MySQL / Redis instead.

COMPOSE_PROFILES=rabbitmq

# MySQL — external: 指向宿主机本地 MySQL
# 容器里 localhost 是容器自己，macOS/Windows 请用 host.docker.internal
CH_DB_HOST=host.docker.internal
CH_DB_PORT=3306
CH_DB_NAME=chhub
CH_DB_USER=chhub
CH_DB_PASSWORD=chhub_pwd
CH_DB_ROOT_PASSWORD=root123456

# Redis — external: 指向宿主机本地 Redis
CH_REDIS_HOST=host.docker.internal
CH_REDIS_PORT=6379
CH_REDIS_PASSWORD=

# Security
CH_JWT_SECRET=please-change-me-this-is-compose-default-very-long-secret-xyz

# Web / Management
CH_WEB_PORT=80
CH_BACKEND_PORT=8080
CH_RABBITMQ_MGMT_PORT=15672
